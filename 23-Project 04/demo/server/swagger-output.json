            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/specials/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/contactCards/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/testimonials/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/cart/1": {
      "get": {
        "summary": "Get the cart",
        "description": "Retrieves the single shared cart (id=1). The cart contains an items array that can hold multiple pizzas.",
        "responses": {
          "200": {
            "description": "Cart retrieved successfully",
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "1"
                },
                "items": {
                  "type": "array",
                  "example": [
                    "pizza_1",
                    "pizza_2"
                  ],
                  "items": {
                    "type": "string"
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "404": {
            "description": "Cart not found",
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Cart not found"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "summary": "Update the cart",
        "description": "Updates the single shared cart (id=1) by replacing the items array with the new one provided in the request body.",
        "responses": {
          "200": {
            "description": "Cart updated successfully",
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "1"
                },
                "items": {
                  "type": "array",
                  "example": [
                    "pizza_1",
                    "pizza_2"
                  ],
                  "items": {
                    "type": "string"
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "example": [
                      "pizza_1",
                      "pizza_2"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/": {
      "post": {
        "summary": "Create a new order",
        "description": "",
        "responses": {
          "201": {
            "description": "Order created successfully",
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "1713456789000"
                },
                "items": {
                  "type": "array",
                  "example": [
                    "pizza_1",
                    "pizza_2"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "createdAt": {
                  "type": "string",
                  "example": "2026-04-18T00:00:00.000Z"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "example": [
                      "pizza_1",
                      "pizza_2"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
